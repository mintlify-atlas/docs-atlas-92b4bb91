  "keyFeatures": [
    "Kubernetes-native CI/CD pipelines with declarative YAML definitions",
    "Reusable Tasks and Pipelines that run as Kubernetes Pods",
    "Workspaces for sharing data between Tasks in a Pipeline",
    "Parameter substitution and Results for passing data between Tasks",
    "Remote resolution to fetch Tasks and Pipelines from Git, OCI registries, and more",
    "Matrix execution for parallel task runs with different parameter combinations",
    "Custom Tasks for extending Tekton with custom controllers",
    "Trusted Resources with signature verification for secure pipeline execution"
  ],
  "publicApiSurface": [
    "Task - Defines a series of steps to execute in containers",
    "TaskRun - Instantiates and executes a Task",
    "Pipeline - Defines a series of Tasks to execute in order or parallel",
    "PipelineRun - Instantiates and executes a Pipeline",
    "StepAction - Reusable steps that can be referenced in Tasks",
    "CustomRun - Executes custom tasks implemented by external controllers",
    "ResolutionRequest - Fetches resources from remote locations",
    "VerificationPolicy - Defines policies for trusted resource verification",
    "Workspaces - Shared filesystem volumes between Tasks",
    "Parameters - Input values for Tasks and Pipelines",
    "Results - Output values from Tasks and Pipelines",
    "When Expressions - Conditional execution guards for Tasks"
  ]
}
